# ─── NexHire Backend Environment ─────────────────────────────
# Copy this file to `config.env` and fill in real values.
# NEVER commit the real config.env (it is gitignored).

PORT=4000
NODE_ENV=development

# MongoDB connection string
DB_URI=mongodb://localhost:27017/NexHire

# Frontend origin allowed by CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000

# Auth — generate a long random secret, e.g. `openssl rand -hex 64`
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRE=7d
COOKIE_EXPIRE=7

# Cloudinary (file/image/resume uploads)
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
